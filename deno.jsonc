{
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env src/main.ts",
    "start": "deno run --allow-net --allow-env src/main.ts",
    "compile": "deno compile --allow-net --allow-env --output dist/tongwen src/main.ts",
    "smoke": "deno run --allow-net --allow-env scripts/smoke.ts"
  },
  "imports": {
    "opencc-js": "npm:opencc-js@^1.0.5"
  },
  "compilerOptions": { "strict": true },
  "fmt": { "singleQuote": true }
}
