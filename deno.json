{
  "compilerOptions": { "strict": true },
  "fmt": { "lineWidth": 90, "singleQuote": true },
  "imports": { "opencc-js": "npm:opencc-js@^1.0.5" },
  "tasks": {
    "build": "deno compile --allow-env --allow-net --output dist/tongwen src/main.ts",
    "serve": "deno run --allow-env --allow-net src/main.ts",
    "smoke": "deno run --allow-env --allow-net scripts/smoke.ts"
  }
}
